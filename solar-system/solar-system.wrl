DEF MERCURY_TIMER TimeSensor {
  cycleInterval 8
  loop TRUE
}
DEF MERCURY_INTERP OrientationInterpolator {
  key [0, 0.25, 0.5, 0.75, 1]
  keyValue [
    0 1 0 0,
    0 1 0 1.5708,
    0 1 0 3.1416,
    0 1 0 4.7124,
    0 1 0 6.2832
  ]
}
ROUTE MERCURY_TIMER.fraction_changed TO MERCURY_INTERP.set_fraction
ROUTE MERCURY_INTERP.value_changed TO MERCURY_ORBIT.set_rotation

DEF MERCURY_TIMER_ROTATION TimeSensor {
  cycleInterval 4
  loop TRUE
}
DEF MERCURY_ROTATION_INTERP OrientationInterpolator {
  key [0, 0.25, 0.5, 0.75, 1]
  keyValue [
    0 1 0 0,
    0 1 0 1.5708,
    0 1 0 3.1416,
    0 1 0 4.7124,
    0 1 0 6.2832
  ]
}
ROUTE MERCURY_TIMER_ROTATION.fraction_changed TO MERCURY_ROTATION_INTERP.set_fraction
ROUTE MERCURY_ROTATION_INTERP.value_changed TO MERCURY_SPIN.set_rotation

