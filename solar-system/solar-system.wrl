#VRML V2.0 utf8

Background {
  frontUrl  "space.jpg"
  backUrl   "space.jpg"
  leftUrl   "space.jpg"
  rightUrl  "space.jpg"
  topUrl    "space.jpg"
  bottomUrl "space.jpg"
}



Transform {
  translation 0 0 0
  children [
    PointLight {
      location 0 0 0
      intensity 1
      ambientIntensity 0.5
      radius 200
      color 1 1 0.9
    }

    Shape {
      appearance Appearance {
        texture ImageTexture {
          url "sun.jpg" # source https://svs.gsfc.nasa.gov/3851/
        }
      }
      geometry Sphere {
        radius 4
      }
    }
  ]
}

DEF MERCURY_ORBIT Transform {
  rotation 0 1 0 4.9188
  children [
    DEF MERCURY_ROT Transform {
      translation 7 0 0
      children [
        DEF MERCURY_SPIN Transform {
          children [
            Shape {
              appearance Appearance {
                material Material {
                }
                texture ImageTexture {
                  url "planets/mercury.jpg"
                }
              }
              geometry Sphere {
                radius 0.6
              }
            }
          ]
        }
      ]
    }
  ]
}

