#VRML V2.0 utf8

# Tree 1
Transform {
    translation 5 0 0
    children [

        Shape {
            geometry Cylinder {
                radius 1.0
                height 5.0
            }
            appearance Appearance {
                texture ImageTexture {
                    url "textures/trunk.webp"
                }
            }
        }
        Transform {
            translation 0 4 0
            children [
                Shape{
                        geometry Sphere {
                        radius 3.0
                    }
                    appearance Appearance {
                        texture ImageTexture {
                            url "textures/grass.jpg"
                        }
                    }
                }
            ]
        }
    ]
}

