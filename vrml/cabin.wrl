# Table
Transform {
    translation 0 -0.5 22
    children [
        # Leg
        Shape {
            geometry Cylinder {
                radius 0.3
                height 3.0
            }
            appearance Appearance {
                texture ImageTexture {
                    url "textures/wood.webp"
                }
            }
        }
        Transform {
            translation 4 1.5 0
            children [
                Shape {
                    geometry Box {
                        size 2 6 0
                    }
                    appearance Appearance {
                        material Material {
                            transparency 0.01
                        }
                        texture MovieTexture {
                            loop TRUE
                            url "textures/guest.gif"
                        }
                    }
                }
                
            ]
        }
        # Tabletop
        Transform {
            translation 0 1.6 0
            children [
                Shape {
                    geometry Cylinder {
                        radius 2.5
                        height 0.2
                    }
                    appearance Appearance {
                        texture ImageTexture {
                            url "textures/wood.webp"
                        }
                    }
                }
            ]
        }
        # Desk lamp
        Transform {
            translation 1 1.7 0
            children [
                # Base
                Shape {
                    geometry Cylinder { radius 0.25 height 0.1 }
                    appearance Appearance {
                        material Material { diffuseColor 0.3 0.3 0.3 }
                    }
                }
                # Pole
                Transform {
                    translation 0 0.7 0
                    children [
                        Shape {
                            geometry Cylinder { radius 0.06 height 1.3 }
                            appearance Appearance {
                                material Material { diffuseColor 0.3 0.3 0.3 }
                            }
                        }
                    ]
                }
                # Shade (tilted)
                Transform {
                    translation 0.1 1.2 0
                    rotation 0 0 1 0.8
                    children [
                        Shape {
                            geometry Cone { height 0.6 bottomRadius 0.45 }
                            appearance Appearance {
                                material Material { diffuseColor 0.3 0.3 0.3 }
                            }
                        }
                        # Bulb
                        Transform {
                            translation 0 -0.35 0
                            children [
                                Shape {
                                    geometry Cylinder 
                                    { radius 0.45 height 0.01}
                                    appearance Appearance {
                                        material Material {
                                            diffuseColor 1.0 1.0 0.8
                                            emissiveColor 0.9 0.9 0.5
                                        }
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
