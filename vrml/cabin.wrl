#VRML V2.0 utf8

# Cabin windows
Transform {
    translation -5 3 14.4
    children [
        Shape {
            geometry Box { size 4 3 0.1 }
            appearance Appearance {
                material Material {
                    diffuseColor 0.6 0.85 1.0
                    transparency 0.4
                }
            }
        }
    ]
}
Transform {
    translation 5 3 14.4
    children [
        Shape {
            geometry Box { size 4 3 0.1 }
            appearance Appearance {
                material Material {
                    diffuseColor 0.6 0.85 1.0
                    transparency 0.4
                }
            }
        }
    ]
}

# Cabin floor
Transform {
    translation 0 -2 22.5
    children [
        Shape {
            geometry Box {
                size 20 0.2 15
            }
            appearance Appearance {
                texture ImageTexture {
                    url "textures/wood.webp"
                }
            }
        }
    ]
}

