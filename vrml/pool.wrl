#VRML V2.0 utf8

# Pool
Transform {
    translation -15 -2 -10
    children [
        # Water surface
        Transform {
            translation 0 1.2 0
            children [
                Shape {
                    geometry Box {
                        size 10 0.3 10
                    }
                    appearance Appearance {
                        material Material {
                            diffuseColor 1.0 1.0 1.0
                            transparency 0.4
                        }
                        texture MovieTexture {
                            loop TRUE
                            startTime 0
                            url "textures/water.gif"
                        }
                    }
                }
            ]
        }
        # North wall
        Transform {
            translation 0 1 5.5
            children [
                Shape {
                    geometry Box { size 12 2 1 }
                    appearance Appearance {
                        material Material { diffuseColor 0.75 0.75 0.75 }
                    }
                }
            ]
        }
        # South wall
        Transform {
            translation 0 1 -5.5
            children [
                Shape {
                    geometry Box { size 12 2 1 }
                    appearance Appearance {
                        material Material { diffuseColor 0.75 0.75 0.75 }
                    }
                }
            ]
        }
        # East wall
        Transform {
            translation 5.5 1 0
            children [
                Shape {
                    geometry Box { size 1 2 10 }
                    appearance Appearance {
                        material Material { diffuseColor 0.75 0.75 0.75 }
                    }
                }
            ]
        }
        # West wall
        Transform {
            translation -5.5 1 0
            children [
                Shape {
                    geometry Box { size 1 2 10 }
                    appearance Appearance {
                        material Material { diffuseColor 0.75 0.75 0.75 }
                    }
                }
            ]
        }
        # Pool floor
        Transform {
            translation 0 -1 0
            children [
                Shape {
                    geometry Box { size 10 2 10 }
                    appearance Appearance {
                        material Material { diffuseColor 0.6 0.75 0.85 }
                    }
                }
            ]
        }
    ]
}
